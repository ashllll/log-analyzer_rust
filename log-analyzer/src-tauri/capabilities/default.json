{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "应用默认权限集合 - 包含所有自定义 IPC 命令与核心插件权限",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:allow-open-url"
  ]
}
