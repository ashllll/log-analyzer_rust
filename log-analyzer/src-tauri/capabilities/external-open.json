{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "external-open",
  "description": "外链打开权限 - 仅允许系统默认程序打开常见 URL 协议",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://*" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    }
  ]
}
