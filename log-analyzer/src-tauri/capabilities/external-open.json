{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "external-open",
  "description": "外链打开权限 - 仅允许系统默认程序打开业务必需域名",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/ashllll/log-analyzer_rust" },
        { "url": "https://github.com/ashllll/log-analyzer_rust/*" },
        { "url": "mailto:*" },
        { "url": "tel:*" }
      ]
    }
  ]
}
